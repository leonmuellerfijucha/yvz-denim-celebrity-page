  <style>
    html {
      height: 100%;
      font-family: sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
      overscroll-behavior-y: auto;
      overscroll-behavior-x: none;
      -webkit-tap-highlight-color: transparent;
      -webkit-font-smoothing: antialiased;
      -webkit-text-size-adjust: 100%;
          -ms-text-size-adjust: 100%;
    }

    body {
      margin: 0;
      height: 100%;
      background-color: #282F3D;
      /* background-color: #FFF; */
      scrollbar-width: thin;
      scrollbar-color: var(--scrollbar-thumb, #9FA3AC) var(--scrollbar-track, transparent);
      -webkit-user-select: none;
         -moz-user-select: none;
          -ms-user-select: none;
              user-select: none;
    }

    @media (hover: hover) and (pointer: fine) {
      body {
        overflow: hidden;
      }
    }

    #root {
      display: flex;
      height: 100%;
      width: 100%;
    }

    a {text-decoration: none}
    svg {display: block}

    .text-link:hover {
      text-decoration: underline;
    }

    [type=file] {
      opacity: 0;
      z-index: 1;
    }

    [type=file],
    [type=file] + label {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      cursor: pointer;
      padding: 1px;
      box-sizing: content-box;
      margin: -1px
    }

    [type=file]:focus + label {
      outline: 1px dotted #000;
      outline: -webkit-focus-ring-color auto 5px;
    }

    ::-moz-selection {
      color: white;
      background: #0070F0;
    }

    ::-webkit-selection {
      color: white;
      background: #0070F0;
    }

    ::selection {
      color: white;
      background: #0070F0;
    }
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }
    ::-webkit-scrollbar-track {
      background: var(--scrollbar-track, transparent);
    }
    ::-webkit-scrollbar-thumb {
      background-color: var(--scrollbar-thumb, #9FA3AC);
      border-radius: 4px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background-color: var(--scrollbar-thumb-hover, #707580);
    }
    ::-webkit-scrollbar-corner {
      background-color: var(--scrollbar-track, transparent);
    }
    .react-pdf-page-custom {
      display: flex;
      flex-direction: row;
      justify-content: center;
      background-color: black;
      margin-bottom: 10px;
      margin-top: 10px;
    }
    .vds-poster-horizontal {
      height: auto;
    }
    .vds-poster-vertical {
      width: auto;
    }

    /* RecyclerListView tooltip cutoff workaround */
    [data-testid="file-list-view"] > div > div > div > div {
      overflow: visible;
    }
    [data-media-provider] {
      justify-content: center;
    }

    input {
      outline: none;
    }

  #WorkspaceBrowser { min-width: 170px; }
  #FoldersAndFiles { min-width: 350px; }
  #InfoPanel { min-width: 250px; }
  #ShareConfiguration { min-width: 250px; }
  #AIChat { min-width: 350px; }
  </style>
