  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <script>try{var h2=location.hostname;var bd2=['fast.io','fastdev1.com','fastlocal.com'];if(!bd2.some((d)=> h2===d||h2.endsWith(`.${d}`))){var gf=document.getElementById('gtm-noscript');if(gf)gf.remove()}}catch(e){}</script>
  <!-- End Google Tag Manager (noscript) -->
  <div id="root">
    <div id="app-loader" style="
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-family: system-ui, -apple-system, sans-serif;
      color: #fff;
      text-align: center;
      opacity: 0;
      transition: opacity 0.3s ease;
    ">
      <div style="font-size: 18px; margin-bottom: 10px;">Loading Fast.io...</div>
      <div style="
        width: 40px;
        height: 40px;
        border: 3px solid #f3f3f3;
        border-top: 3px solid #0070F0;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 0 auto;
      "></div>
      <style>
        @keyframes spin {
          0% { transform: rotate(0deg); }
          100% { transform: rotate(360deg); }
        }
      </style>
    </div>
  </div>
  <script>
    try {
      setTimeout(() => {
        var loader = document.getElementById('app-loader');
        if (loader) loader.style.opacity = '1';
      }, 2000);
    } catch(e) { console.warn('[App loader] Failed:', e) }
  </script>
  <div id="portal"></div>
</body>
